[
  {
    "Name": "BillingService",
    "Description": "Logs from the billing processing service",
    "SourcePath": "C:\\Logs\\BillingService",
    "DestinationPath": "D:\\Archives\\BillingService",
    "FileNamePattern": "^billing.*\\.log$",
    "ArchiveNamePrefix": "BILLING",
    "CleanSourceFiles": false,
    "RotateDaily": 90,
    "CompressionAlgorithm": "-tzip",
    "CompressionMethod": "-mm=Deflate",
    "CompressionLevel": 9,
    "ReceiptFileName": "receipt.json"
  },
  {
    "Name": "CostAnalytics",
    "Description": "Logs from the cost analytics and reporting engine",
    "SourcePath": "C:\\Logs\\CostAnalytics",
    "DestinationPath": "D:\\Archives\\CostAnalytics",
    "FileNamePattern": "^cost-.*\\.log$",
    "ArchiveNamePrefix": "COST",
    "CleanSourceFiles": false,
    "RotateDaily": 90,
    "CompressionAlgorithm": "-tzip",
    "CompressionMethod": "-mm=Deflate",
    "CompressionLevel": 9,
    "ReceiptFileName": "receipt.json"
  },
  {
    "Name": "BudgetMonitor",
    "Description": "Logs from the budget alerting and threshold monitoring service",
    "SourcePath": "C:\\Logs\\BudgetMonitor",
    "DestinationPath": "D:\\Archives\\BudgetMonitor",
    "FileNamePattern": "^budget-.*\\.log$",
    "ArchiveNamePrefix": "BUDGET",
    "CleanSourceFiles": false,
    "RotateDaily": 90,
    "CompressionAlgorithm": "-tzip",
    "CompressionMethod": "-mm=Deflate",
    "CompressionLevel": 9,
    "ReceiptFileName": "receipt.json"
  }
]
